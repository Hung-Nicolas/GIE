# Variables del frontend (Vite)
VITE_SUPABASE_URL=https://tu-proyecto-gie.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Variables para Edge Functions de GIE (no se exponen al frontend)
# Se configuran en Supabase Dashboard → Edge Functions → Secrets
# o en supabase/config.toml bajo [edge_runtime.secrets]
SUPABASE_URL=https://tu-proyecto-gie.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Gateway de Nexus (api-nexus)
NEXUS_GATEWAY_URL=https://tu-proyecto-nexus.supabase.co/functions/v1/api-nexus
NEXUS_API_KEY=nx_...
